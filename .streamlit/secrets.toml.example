# Copy this file to secrets.toml and paste your real credentials.
#   cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#
# Streamlit Cloud: paste the same blocks in App settings -> Secrets.
# Do not commit secrets.toml to Git.

[supabase]
url = "https://YOUR_PROJECT_ID.supabase.co"
key = "YOUR_SUPABASE_SERVICE_ROLE_KEY"

# Shopify Dev Dashboard app (2026+): Client ID + Client Secret
# Dev Dashboard -> Apps -> Your app -> Settings
# App must be installed on the same store. Token auto-fetches (~24h expiry).
#
# Required Admin API scopes (merchant must approve on install):
#   read_products, write_products, read_inventory, write_inventory, read_locations
[shopify]
store_url = "your-store.myshopify.com"
client_id = "your_dev_dashboard_client_id"
client_secret = "shpss_your_dev_dashboard_client_secret"
api_version = "2024-10"

# Optional legacy fallback (old admin custom apps only):
# access_token = "shpat_your_admin_api_access_token"

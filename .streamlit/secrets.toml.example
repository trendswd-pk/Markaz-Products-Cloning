# Copy this file to secrets.toml and paste your real Supabase values.
#   cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#
# Use the service_role key here (Settings -> API -> service_role).
# Keep it server-side only; never expose it in browser or Git.
#
# RLS is enabled on tracked_products. The service_role key is used by
# Streamlit backend only. Public/anon access stays blocked.
#
# Streamlit Cloud: paste the same [supabase] block in
# App settings -> Secrets (do not commit secrets.toml to Git).

[supabase]
url = "https://YOUR_PROJECT_ID.supabase.co"
key = "YOUR_SUPABASE_SERVICE_ROLE_KEY"
